{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/**/*.cs"
          ]
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "noRestore": false,
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "allowCompilationErrors": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
//      },
//      {
//        "files": [
//          "docs/**/*.md"
//        ]
      }
    ],
//    "resource": [
//      {
//        "files": [
//          "docs/**/*"
//        ]
//      }
//    ],
    "output": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}